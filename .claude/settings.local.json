      "Bash(fi)",
      "Bash(done)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(python3 *)",
      "Bash(git add *)",
      "Bash(git commit -m 'fix: render Hugo figure shortcode in newsletter emails *)"
    ]
  }
}
